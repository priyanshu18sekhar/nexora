generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                   String                  @id @default(cuid())
  name                 String?
  email                String?                 @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 UserRole                @default(STUDENT)
  bio                  String?
  headline             String?
  location             String?
  website              String?
  linkedinUrl          String?
  githubUrl            String?
  phone                String?
  resumeUrl            String?
  skills               String[]
  isVerified           Boolean                 @default(false)
  isActive             Boolean                 @default(true)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  accounts             Account[]
  certificates         Certificate[]
  coursesCreated       Course[]                @relation("CourseInstructor")
  enrollments          Enrollment[]
  internshipsPosted    Internship[]            @relation("InternshipRecruiter")
  applications         InternshipApplication[]
  lessonProgress       LessonProgress[]
  liveClassEnrollments LiveClassEnrollment[]
  notifications        Notification[]
  payments             Payment[]
  quizAttempts         QuizAttempt[]
  reviews              Review[]
  sessions             Session[]
}

model Course {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  description   String
  shortDesc     String?
  thumbnail     String?
  previewVideo  String?
  price         Float         @default(0)
  currency      String        @default("INR")
  isFree        Boolean       @default(false)
  level         CourseLevel   @default(BEGINNER)
  status        CourseStatus  @default(DRAFT)
  tags          String[]
  language      String        @default("English")
  duration      Int?
  totalLessons  Int           @default(0)
  rating        Float         @default(0)
  totalRatings  Int           @default(0)
  totalStudents Int           @default(0)
  instructorId  String
  categoryId    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  certificates  Certificate[]
  category      Category?     @relation(fields: [categoryId], references: [id])
  instructor    User          @relation("CourseInstructor", fields: [instructorId], references: [id])
  enrollments   Enrollment[]
  reviews       Review[]
  sections      Section[]

  @@index([instructorId])
  @@index([categoryId])
  @@index([slug])
}

model Section {
  id        String   @id @default(cuid())
  title     String
  order     Int
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lessons   Lesson[]
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Lesson {
  id          String           @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  duration    Int?
  order       Int
  isFree      Boolean          @default(false)
  lessonType  LessonType       @default(VIDEO)
  sectionId   String
  resources   Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  section     Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]
  quiz        Quiz?

  @@index([sectionId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  isCompleted Boolean  @default(false)
  watchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  progress    Float            @default(0)
  paymentId   String?
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  updatedAt   DateTime         @updatedAt
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model Quiz {
  id           String         @id @default(cuid())
  title        String
  description  String?
  lessonId     String         @unique
  passingScore Int            @default(70)
  timeLimit    Int?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  lesson       Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts     QuizAttempt[]
  questions    QuizQuestion[]
}

model QuizQuestion {
  id           String  @id @default(cuid())
  quizId       String
  question     String
  options      Json
  correctIndex Int
  explanation  String?
  order        Int
  quiz         Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  answers     Json
  score       Float
  passed      Boolean  @default(false)
  attemptedAt DateTime @default(now())
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

model Category {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  icon        String?
  description String?
  color       String?
  courses     Course[]
  internships Internship[]
}

model Internship {
  id           String                  @id @default(cuid())
  title        String
  slug         String                  @unique
  company      String
  companyLogo  String?
  description  String
  requirements String?
  location     String
  isRemote     Boolean                 @default(false)
  stipend      Float?
  currency     String                  @default("INR")
  duration     String
  skills       String[]
  status       InternshipStatus        @default(OPEN)
  deadline     DateTime?
  openings     Int                     @default(1)
  categoryId   String?
  recruiterId  String
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  category     Category?               @relation(fields: [categoryId], references: [id])
  recruiter    User                    @relation("InternshipRecruiter", fields: [recruiterId], references: [id])
  applications InternshipApplication[]

  @@index([recruiterId])
  @@index([slug])
}

model InternshipApplication {
  id            String            @id @default(cuid())
  userId        String
  internshipId  String
  status        ApplicationStatus @default(PENDING)
  coverLetter   String?
  resumeUrl     String?
  portfolioUrl  String?
  recruiterNote String?
  appliedAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  internship    Internship        @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, internshipId])
  @@index([internshipId])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  amount          Float
  currency        String        @default("INR")
  status          PaymentStatus @default(PENDING)
  provider        String        @default("paypal")
  providerTxnId   String?
  providerOrderId String?
  metadata        Json?
  courseId        String?
  internshipId    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerOrderId])
}

model Certificate {
  id               String            @id @default(cuid())
  userId           String
  courseId         String
  certificateNo    String            @unique @default(cuid())
  verificationCode String            @unique @default(cuid())
  status           CertificateStatus @default(PENDING)
  score            Float?
  issuedAt         DateTime?
  pdfUrl           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  course           Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([verificationCode])
}

model LiveClass {
  id           String                @id @default(cuid())
  title        String
  description  String?
  scheduledAt  DateTime
  duration     Int                   @default(60)
  meetLink     String?
  recordingUrl String?
  status       LiveClassStatus       @default(SCHEDULED)
  thumbnail    String?
  maxStudents  Int?
  tags         String[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  enrollments  LiveClassEnrollment[]
}

model LiveClassEnrollment {
  id          String    @id @default(cuid())
  userId      String
  liveClassId String
  joinedAt    DateTime  @default(now())
  attended    Boolean   @default(false)
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, liveClassId])
  @@index([liveClassId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum UserRole {
  STUDENT
  PROFESSIONAL
  MENTOR
  RECRUITER
  ADMIN
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum InternshipStatus {
  OPEN
  CLOSED
  FILLED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum CertificateStatus {
  PENDING
  ISSUED
  REVOKED
}

enum LessonType {
  VIDEO
  QUIZ
  ASSESSMENT
}

enum LiveClassStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}
